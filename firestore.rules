rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    
    function isOwner(doc) {
      return isSignedIn() && doc.ownerId == request.auth.uid;
    }

    function isValidRental(data) {
      return data.keys().hasAll(['title', 'description', 'price', 'location', 'bedrooms', 'bathrooms', 'sizeSqft', 'contactPhone', 'ownerId', 'createdAt', 'updatedAt', 'status'])
        && data.title is string && data.title.size() > 0 && data.title.size() <= 200
        && data.description is string && data.description.size() <= 5000
        && data.price is number && data.price >= 0
        && data.location is string && data.location.size() > 0 && data.location.size() <= 200
        && data.bedrooms is number && data.bedrooms >= 0 && data.bedrooms <= 50
        && data.bathrooms is number && data.bathrooms >= 0 && data.bathrooms <= 50
        && data.sizeSqft is number && data.sizeSqft >= 0
        && data.contactPhone is string && data.contactPhone.size() > 0 && data.contactPhone.size() <= 20
        && data.ownerId is string && data.ownerId == request.auth.uid
        && data.status in ['available', 'rented']
        && (!('hidePhone' in data) || data.hidePhone is bool)
        && (!('photoUrls' in data) || (data.photoUrls is list && data.photoUrls.size() <= 10))
        && (!('propertyType' in data) || data.propertyType is string && data.propertyType.size() <= 50)
        && (!('amenities' in data) || (data.amenities is list && data.amenities.size() <= 20))
        && (!('lat' in data) || (data.lat is number && data.lat >= -90 && data.lat <= 90))
        && (!('lng' in data) || (data.lng is number && data.lng >= -180 && data.lng <= 180))
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    function isValidChat(data) {
      return data.keys().hasAll(['rentalId', 'rentalTitle', 'participants', 'lastMessage', 'lastMessageTime', 'createdAt'])
        && data.rentalId is string && data.rentalTitle is string
        && data.participants is list && data.participants.size() == 2
        && data.participants[0] is string && data.participants[1] is string
        && data.lastMessage is string && data.lastMessage.size() <= 500
        && data.lastMessageTime is timestamp
        && data.createdAt is timestamp;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['text', 'senderId', 'createdAt'])
        && data.text is string && data.text.size() > 0 && data.text.size() <= 2000
        && data.senderId is string && data.senderId == request.auth.uid
        && data.createdAt is timestamp;
    }

    match /rentals/{rentalId} {
      allow get: if true;
      allow list: if true; // Public listings
      
      allow create: if isSignedIn()
        && isValidId(rentalId)
        && isValidRental(incoming())
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;
        
      allow update: if isSignedIn()
        && isOwner(existing())
        && isValidRental(incoming())
        && incoming().ownerId == existing().ownerId
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time
        && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'price', 'location', 'bedrooms', 'bathrooms', 'sizeSqft', 'contactPhone', 'hidePhone', 'photoUrls', 'propertyType', 'amenities', 'status', 'updatedAt', 'lat', 'lng']);
        
      allow delete: if isOwner(existing());
    }

    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow list: if false;
      allow write: if isSignedIn() && request.auth.uid == userId;
      
      match /favorites/{favoriteId} {
        allow read: if isSignedIn() && request.auth.uid == userId;
        allow write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    match /chats/{chatId} {
      allow get: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow list: if isSignedIn() && request.auth.uid in resource.data.participants;
      
      allow create: if isSignedIn()
        && isValidId(chatId)
        && isValidChat(incoming())
        && request.auth.uid in incoming().participants
        && incoming().createdAt == request.time
        && incoming().lastMessageTime == request.time
        && exists(/databases/$(database)/documents/rentals/$(incoming().rentalId))
        && get(/databases/$(database)/documents/rentals/$(incoming().rentalId)).data.ownerId in incoming().participants;

      allow update: if isSignedIn()
        && request.auth.uid in existing().participants
        && incoming().diff(existing()).affectedKeys().hasOnly(['lastMessage', 'lastMessageTime'])
        && incoming().lastMessage is string
        && incoming().lastMessageTime == request.time;

      match /messages/{messageId} {
        allow read: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isSignedIn()
          && isValidId(messageId)
          && request.auth.uid in getAfter(/databases/$(database)/documents/chats/$(chatId)).data.participants
          && isValidMessage(incoming())
          && incoming().createdAt == request.time;
      }
    }
  }
}
